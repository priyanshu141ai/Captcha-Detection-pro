CIPHERLENS_CONFIG=configs/default.yaml
CIPHERLENS_CHECKPOINT=models/captcha_crnn.pt
CIPHERLENS_TORCH_THREADS=2
CIPHERLENS_CONFIDENCE_THRESHOLD=0.75
CIPHERLENS_MAX_UPLOAD_BYTES=10485760
CIPHERLENS_MAX_UPLOAD_PIXELS=4000000
CIPHERLENS_LOG_LEVEL=INFO
CIPHERLENS_LOG_FORMAT=console
CIPHERLENS_API_MAX_BATCH_SIZE=8
CIPHERLENS_API_MAX_CONCURRENCY=1
CIPHERLENS_FRONTEND_API_URL=http://api:8000
CIPHERLENS_API_TIMEOUT_SECONDS=15
CIPHERLENS_LOCAL_FALLBACK=true
CIPHERLENS_API_PORT=8000
CIPHERLENS_FRONTEND_PORT=8501
CIPHERLENS_API_CPUS=2.0
CIPHERLENS_API_MEMORY=2G
CIPHERLENS_FRONTEND_CPUS=1.0
CIPHERLENS_FRONTEND_MEMORY=1G
CIPHERLENS_IMAGE=cipherlens:local
# CIPHERLENS_MODEL_HOST_PATH=C:/absolute/path/to/approved-captcha-crnn.pt
